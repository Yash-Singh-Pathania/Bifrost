{
  "name": "video-search",
  "version": "1.0.0",
  "description": "Semantic video search engine — find any moment by text or visual query",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "setup:python": "cd python && bash setup.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "ollama": "^0.5.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^9.0.0",
    "vectordb": "^0.4.20"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.videosearch.app",
    "productName": "Video Search",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "python/**/*",
      "!python/venv/**",
      "!python/__pycache__/**"
    ],
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}
